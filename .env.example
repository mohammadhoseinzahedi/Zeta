# Authentication
# Generate a secure key using: openssl rand -base64 32
# Or use: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=your-super-secret-key-here-at-least-32-characters

# Database (PostgreSQL)
# For production, use your cloud database URL (Neon, Supabase, etc.)
# For local development with Docker: postgresql://postgres:password@localhost:5432/mydb
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Owner credentials for admin access
# IMPORTANT: Change these from default values
OWNER_USERNAME=your_admin_username
OWNER_PASSWORD=your_secure_admin_password
